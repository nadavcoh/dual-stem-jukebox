# --- Supabase ---
# Use the SERVICE ROLE key here (not anon) — the worker needs to
# bypass RLS to update job status regardless of who queued it.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Backblaze B2 (S3-compatible) ---
# Read-write key — this is the ONLY place this key pair should ever be
# used. The Next.js app gets its own separate, read-only key (see
# web/.env.local.example) so a leaked frontend credential can never be
# used to overwrite or delete anything in the bucket.
B2_RW_KEY_ID=your-read-write-application-key-id
B2_RW_APPLICATION_KEY=your-read-write-application-key
B2_BUCKET_NAME=dual-stem-jukebox
# Find this in the B2 bucket "Endpoint" field, e.g.:
B2_ENDPOINT_URL=https://s3.us-west-002.backblazeb2.com
B2_REGION=us-west-002

# --- Worker behavior ---
WORKER_ID=worker-1
POLL_INTERVAL_SECONDS=5
STALE_JOB_TIMEOUT_MINUTES=30
WORK_DIR=./tmp
# 2-stem demucs model to use (vocals vs. everything-else)
DEMUCS_MODEL=htdemucs
