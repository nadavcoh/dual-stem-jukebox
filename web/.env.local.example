# Public — safe to expose to the browser. Used for read-only queries
# (polling track status) directly from client components. The publishable
# key carries the same low privileges as the legacy anon key — find it
# under Project Settings > API Keys > Publishable key (sb_publishable_...).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Server-only — NEVER prefix with NEXT_PUBLIC_. Used inside Server
# Actions to insert queue rows, bypassing RLS, regardless of who's
# logged in (this app has no end-user auth, just a shared queue).
# Find it under Project Settings > API Keys > Secret keys (sb_secret_...).
# Legacy service_role keys still work too, but are being phased out by
# end of 2026 — use the new key type if your project has one.
SUPABASE_SECRET_KEY=sb_secret_...

# --- Backblaze B2 (S3-compatible) — private bucket ---
# Read-ONLY key, separate from the worker's read-write key (see
# worker/.env.example). This app can only ever generate GET presigned
# URLs with it — it has no ability to upload or delete, even if this
# value leaked.
B2_READ_KEY_ID=your-read-only-application-key-id
B2_READ_APPLICATION_KEY=your-read-only-application-key
B2_BUCKET_NAME=dual-stem-jukebox
# Same endpoint/region as the worker's B2 config — find this in the B2
# bucket's "Endpoint" field, e.g.:
B2_ENDPOINT_URL=https://s3.us-west-002.backblazeb2.com
B2_REGION=us-west-002
