# Public — safe to expose to the browser. Used for read-only queries
# (polling track status) directly from client components.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — NEVER prefix with NEXT_PUBLIC_. Used inside Server
# Actions to insert queue rows, bypassing RLS, regardless of who's
# logged in (this app has no end-user auth, just a shared queue).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
